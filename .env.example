# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://taverntable:password@localhost:5432/taverntable

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis for real-time game state (24h TTL) and campaign memory cache
REDIS_URL=redis://localhost:6379

# ─── AI Dungeon Master ────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
# Used for: narrative generation (claude-opus-4-5), combat narration (claude-haiku-4-5)
ANTHROPIC_API_KEY=sk-ant-api03-...

# AI DM model configuration (defaults shown)
AI_DM_MODEL=claude-opus-4-5
AI_DM_COMBAT_MODEL=claude-haiku-4-5
AI_DM_MAX_TOKENS=300
AI_DM_STREAM=true

# ─── Stripe (Premium Cosmetics) ───────────────────────────────────────────────
# Get your keys at: https://dashboard.stripe.com/apikeys
# Gameplay is always free — Stripe only for cosmetic upgrades
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products at: https://dashboard.stripe.com/products
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_YEARLY_PRICE_ID=price_...

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Random secret for session signing (generate: openssl rand -hex 32)
SESSION_SECRET=change-me-in-production

# ─── Optional: Observability ──────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# LOG_LEVEL=info
